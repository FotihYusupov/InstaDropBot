# Telegram Bot Configuration
BOT_TOKEN=your_telegram_bot_token

# MongoDB Configuration
# For local Mongoose connection: mongodb://localhost:27017/instadrop
MONGO_URL=mongodb://localhost:27017/instadrop

# Server Port (used for HTTP health check)
PORT=3000

# Download Concurrency Settings
# Maximum number of yt-dlp downloads to run at the same time
MAX_CONCURRENT_DOWNLOADS=2

# Rate Limiting per User
# Allow max RATE_LIMIT_LIMIT downloads every RATE_LIMIT_WINDOW_MS
RATE_LIMIT_LIMIT=5
RATE_LIMIT_WINDOW_MS=60000

# Temporary Downloads Directory
DOWNLOAD_DIR=./temp_downloads

# Path to yt-dlp executable (defaults to 'yt-dlp' if in system PATH)
# YT_DLP_PATH=yt-dlp

# Path to cookies.txt file for yt-dlp (optional, bot checks './cookies.txt' by default if not set)
# YT_DLP_COOKIES_PATH=./cookies.txt

# Admin Panel Configuration
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
SESSION_SECRET=a_very_secure_random_string_here

