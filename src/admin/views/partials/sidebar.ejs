<!-- Sidebar -->
<aside class="w-full md:w-64 bg-slate-900 border-b md:border-b-0 md:border-r border-slate-800 flex flex-col shrink-0">
  <!-- Brand Logo Header -->
  <div class="h-16 flex items-center justify-between px-6 border-b border-slate-800">
    <div class="flex items-center space-x-3">
      <div class="w-8 h-8 rounded-lg bg-gradient-to-tr from-brand-600 to-rose-400 flex items-center justify-center shadow-lg shadow-brand-500/20">
        <i class="fa-solid fa-cloud-arrow-down text-white text-sm"></i>
      </div>
      <div>
        <h1 class="text-sm font-bold text-white tracking-wide uppercase">InstaDrop</h1>
        <p class="text-[10px] text-slate-400 font-medium">Telegram Media Bot</p>
      </div>
    </div>
    <!-- Mobile toggle button is handled by parent template if needed, else responsive layouts hide sidebar on mobile, let's keep it visible/scalable -->
  </div>

  <!-- Navigation Links -->
  <nav class="flex-1 px-4 py-6 space-y-1.5 overflow-y-auto">
    <a href="/admin" 
       class="flex items-center space-x-3 px-4 py-2.5 rounded-lg text-sm font-medium transition-all group <%= activePage === 'dashboard' ? 'bg-brand-600 text-white shadow-md shadow-brand-500/10' : 'text-slate-400 hover:bg-slate-800 hover:text-slate-200' %>">
      <i class="fa-solid fa-chart-line w-5 <%= activePage === 'dashboard' ? 'text-white' : 'text-slate-400 group-hover:text-slate-200' %>"></i>
      <span>Dashboard</span>
    </a>

    <a href="/admin/users" 
       class="flex items-center space-x-3 px-4 py-2.5 rounded-lg text-sm font-medium transition-all group <%= activePage === 'users' ? 'bg-brand-600 text-white shadow-md shadow-brand-500/10' : 'text-slate-400 hover:bg-slate-800 hover:text-slate-200' %>">
      <i class="fa-solid fa-users w-5 <%= activePage === 'users' ? 'text-white' : 'text-slate-400 group-hover:text-slate-200' %>"></i>
      <span>Users</span>
    </a>

    <a href="/admin/downloads" 
       class="flex items-center space-x-3 px-4 py-2.5 rounded-lg text-sm font-medium transition-all group <%= activePage === 'downloads' ? 'bg-brand-600 text-white shadow-md shadow-brand-500/10' : 'text-slate-400 hover:bg-slate-800 hover:text-slate-200' %>">
      <i class="fa-solid fa-download w-5 <%= activePage === 'downloads' ? 'text-white' : 'text-slate-400 group-hover:text-slate-200' %>"></i>
      <span>Downloads</span>
    </a>

    <a href="/admin/stats" 
       class="flex items-center space-x-3 px-4 py-2.5 rounded-lg text-sm font-medium transition-all group <%= activePage === 'stats' ? 'bg-brand-600 text-white shadow-md shadow-brand-500/10' : 'text-slate-400 hover:bg-slate-800 hover:text-slate-200' %>">
      <i class="fa-solid fa-chart-pie w-5 <%= activePage === 'stats' ? 'text-white' : 'text-slate-400 group-hover:text-slate-200' %>"></i>
      <span>Analytics</span>
    </a>

    <a href="/admin/logs" 
       class="flex items-center space-x-3 px-4 py-2.5 rounded-lg text-sm font-medium transition-all group <%= activePage === 'logs' ? 'bg-brand-600 text-white shadow-md shadow-brand-500/10' : 'text-slate-400 hover:bg-slate-800 hover:text-slate-200' %>">
      <i class="fa-solid fa-terminal w-5 <%= activePage === 'logs' ? 'text-white' : 'text-slate-400 group-hover:text-slate-200' %>"></i>
      <span>Logs</span>
    </a>
  </nav>

  <!-- User Account / Logout section -->
  <div class="p-4 border-t border-slate-800 bg-slate-950/50">
    <div class="flex items-center justify-between">
      <div class="flex items-center space-x-3">
        <div class="w-9 h-9 rounded-full bg-slate-800 border border-slate-700 flex items-center justify-center text-slate-300 font-bold text-sm">
          A
        </div>
        <div>
          <h2 class="text-xs font-semibold text-white">Administrator</h2>
          <p class="text-[10px] text-slate-500">System Owner</p>
        </div>
      </div>
      <a href="/admin/logout" 
         title="Log Out"
         class="w-8 h-8 rounded-lg border border-slate-800 flex items-center justify-center text-slate-400 hover:bg-slate-800 hover:text-rose-500 transition-colors">
        <i class="fa-solid fa-right-from-bracket text-sm"></i>
      </a>
    </div>
  </div>
</aside>
