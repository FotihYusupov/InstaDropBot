<%- include('partials/header') %>
<%- include('partials/sidebar') %>

<div class="flex-1 flex flex-col overflow-hidden bg-slate-950">
  <%- include('partials/navbar') %>
  
  <main class="flex-1 overflow-y-auto p-6 md:p-8 space-y-6">
    
    <!-- Title -->
    <div>
      <h2 class="text-2xl font-bold text-white tracking-tight">Broadcast Message</h2>
      <p class="text-sm text-slate-400">Send a message to all users registered in the database via the Telegram bot.</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      
      <!-- Composer Card -->
      <div class="lg:col-span-2 bg-slate-900 border border-slate-800 p-6 rounded-2xl shadow-lg space-y-6">
        <h3 class="text-sm font-bold text-white uppercase tracking-wider flex items-center space-x-2">
          <i class="fa-solid fa-pen-to-square text-brand-400"></i>
          <span>Compose Broadcast</span>
        </h3>
        
        <form id="broadcastForm" class="space-y-4">
          <div class="space-y-2">
            <label for="message" class="block text-xs font-semibold text-slate-400 uppercase tracking-wider">Message Content</label>
            <textarea id="message" name="message" rows="8" required
                      class="w-full bg-slate-950 border border-slate-800 rounded-xl px-4 py-3 text-slate-200 text-sm focus:border-brand-500 focus:outline-none transition-colors placeholder-slate-600"
                      placeholder="Draft your message here..."></textarea>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="space-y-2">
              <label for="parseMode" class="block text-xs font-semibold text-slate-400 uppercase tracking-wider">Formatting Mode</label>
              <select id="parseMode" name="parseMode"
                      class="w-full bg-slate-950 border border-slate-800 rounded-xl px-4 py-2.5 text-slate-200 text-sm focus:border-brand-500 focus:outline-none transition-colors">
                <option value="none">Plain Text</option>
                <option value="Markdown">Markdown</option>
                <option value="HTML">HTML</option>
              </select>
            </div>
            
            <div class="flex items-end">
              <button type="submit" id="submitBtn"
                      class="w-full bg-brand-600 hover:bg-brand-500 active:bg-brand-700 text-white font-semibold py-2.5 px-6 rounded-xl text-sm transition-all shadow-lg shadow-brand-600/20 flex items-center justify-center space-x-2">
                <i class="fa-solid fa-paper-plane"></i>
                <span>Start Broadcast</span>
              </button>
            </div>
          </div>
        </form>

        <div id="formFeedback" class="hidden p-4 rounded-xl text-sm font-medium border"></div>
      </div>

      <!-- Live Progress Card -->
      <div class="bg-slate-900 border border-slate-800 p-6 rounded-2xl shadow-lg flex flex-col justify-between">
        <div class="space-y-6">
          <h3 class="text-sm font-bold text-white uppercase tracking-wider flex items-center space-x-2">
            <i class="fa-solid fa-tower-broadcast text-indigo-400"></i>
            <span>Broadcast Status</span>
          </h3>

          <div id="statusContainer" class="space-y-4">
            <!-- Idle Status -->
            <div id="statusIdle" class="flex flex-col items-center justify-center py-10 text-center space-y-3">
              <div class="w-12 h-12 rounded-full bg-slate-800 flex items-center justify-center text-slate-400 text-xl">
                <i class="fa-solid fa-circle-notch fa-spin hidden" id="idleSpinner"></i>
                <i class="fa-solid fa-sleep" id="idleIcon">💤</i>
              </div>
              <p class="text-slate-400 text-sm font-semibold">No active broadcast</p>
              <p class="text-slate-500 text-xs max-w-xs">Draft a message and hit start to begin broadcasting to users.</p>
            </div>

            <!-- Active Status -->
            <div id="statusActive" class="hidden space-y-4">
              <div class="flex items-center justify-between text-xs text-slate-400 font-semibold uppercase tracking-wider">
                <span>Sending Progress</span>
                <span id="progressPercent">0%</span>
              </div>
              
              <!-- Progress Bar -->
              <div class="w-full bg-slate-950 rounded-full h-3.5 border border-slate-800 overflow-hidden">
                <div id="progressBar" class="bg-gradient-to-r from-brand-500 to-indigo-500 h-full rounded-full transition-all duration-300" style="width: 0%"></div>
              </div>

              <!-- Stats Grid -->
              <div class="grid grid-cols-2 gap-3 text-xs">
                <div class="p-3 bg-slate-950 border border-slate-850 rounded-xl">
                  <span class="text-slate-500 block uppercase font-medium">Total Users</span>
                  <span id="statTotal" class="text-white font-black text-sm block mt-0.5">0</span>
                </div>
                <div class="p-3 bg-slate-950 border border-slate-850 rounded-xl">
                  <span class="text-slate-500 block uppercase font-medium">Processed</span>
                  <span id="statProcessed" class="text-white font-black text-sm block mt-0.5">0</span>
                </div>
                <div class="p-3 bg-slate-950 border border-slate-850 rounded-xl">
                  <span class="text-slate-500 block uppercase font-medium">Succeeded</span>
                  <span id="statSuccess" class="text-emerald-400 font-black text-sm block mt-0.5">0</span>
                </div>
                <div class="p-3 bg-slate-950 border border-slate-850 rounded-xl">
                  <span class="text-slate-500 block uppercase font-medium">Failed</span>
                  <span id="statFailed" class="text-rose-400 font-black text-sm block mt-0.5">0</span>
                </div>
              </div>

              <div class="text-[11px] text-slate-500 space-y-1 mt-2">
                <div class="flex justify-between">
                  <span>Status:</span>
                  <span id="statStatus" class="font-bold text-slate-300">Sending</span>
                </div>
                <div class="flex justify-between">
                  <span>Started At:</span>
                  <span id="statStartedAt" class="font-mono text-slate-400">-</span>
                </div>
                <div class="flex justify-between">
                  <span>Finished At:</span>
                  <span id="statFinishedAt" class="font-mono text-slate-400">-</span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="pt-4 border-t border-slate-850 text-[10px] text-slate-500">
          <i class="fa-solid fa-circle-info mr-1"></i> Respects Telegram rate limits (~28 msgs/sec).
        </div>
      </div>

    </div>

  </main>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('broadcastForm');
    const submitBtn = document.getElementById('submitBtn');
    const formFeedback = document.getElementById('formFeedback');
    
    // Status Elements
    const statusIdle = document.getElementById('statusIdle');
    const statusActive = document.getElementById('statusActive');
    const idleIcon = document.getElementById('idleIcon');
    const idleSpinner = document.getElementById('idleSpinner');
    const progressBar = document.getElementById('progressBar');
    const progressPercent = document.getElementById('progressPercent');
    const statTotal = document.getElementById('statTotal');
    const statProcessed = document.getElementById('statProcessed');
    const statSuccess = document.getElementById('statSuccess');
    const statFailed = document.getElementById('statFailed');
    const statStatus = document.getElementById('statStatus');
    const statStartedAt = document.getElementById('statStartedAt');
    const statFinishedAt = document.getElementById('statFinishedAt');

    let pollingInterval = null;

    // Check status on load
    checkBroadcastStatus();

    // Form Submission
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const message = document.getElementById('message').value;
      const parseMode = document.getElementById('parseMode').value;
      
      submitBtn.disabled = true;
      submitBtn.innerHTML = `<i class="fa-solid fa-circle-notch fa-spin mr-2"></i>Starting...`;
      formFeedback.classList.add('hidden');

      try {
        const response = await fetch('/admin/broadcast', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ message, parseMode })
        });

        const data = await response.json();
        
        if (response.ok && data.success) {
          formFeedback.className = 'p-4 rounded-xl text-sm font-medium border bg-emerald-500/10 border-emerald-500/20 text-emerald-400';
          formFeedback.textContent = '🚀 Broadcast successfully started in the background!';
          formFeedback.classList.remove('hidden');
          form.reset();
          
          // Trigger polling
          startPolling();
        } else {
          throw new Error(data.error || 'Failed to start broadcast.');
        }
      } catch (err) {
        formFeedback.className = 'p-4 rounded-xl text-sm font-medium border bg-rose-500/10 border-rose-500/20 text-rose-400';
        formFeedback.textContent = `❌ Error: ${err.message}`;
        formFeedback.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.innerHTML = `<i class="fa-solid fa-paper-plane mr-2"></i>Start Broadcast`;
      }
    });

    function startPolling() {
      if (pollingInterval) clearInterval(pollingInterval);
      pollingInterval = setInterval(checkBroadcastStatus, 1000);
      
      // Update UI state for form button
      submitBtn.disabled = true;
      submitBtn.innerHTML = `<i class="fa-solid fa-tower-broadcast fa-fade mr-2"></i>Broadcasting...`;
    }

    function stopPolling() {
      if (pollingInterval) {
        clearInterval(pollingInterval);
        pollingInterval = null;
      }
      submitBtn.disabled = false;
      submitBtn.innerHTML = `<i class="fa-solid fa-paper-plane mr-2"></i>Start Broadcast`;
    }

    async function checkBroadcastStatus() {
      try {
        const response = await fetch('/admin/broadcast/status');
        if (!response.ok) return;
        const status = await response.json();

        if (status.active) {
          statusIdle.classList.add('hidden');
          statusActive.classList.remove('hidden');
          
          // Update numbers
          statTotal.textContent = status.totalUsers;
          statProcessed.textContent = status.processedUsers;
          statSuccess.textContent = status.successCount;
          statFailed.textContent = status.failedCount;
          statStatus.textContent = 'Sending...';
          statStatus.className = 'font-bold text-indigo-400';

          statStartedAt.textContent = status.startedAt ? new Date(status.startedAt).toLocaleString() : '-';
          statFinishedAt.textContent = '-';

          // Update Progress Bar
          const percentage = status.totalUsers > 0 
            ? Math.round((status.processedUsers / status.totalUsers) * 100) 
            : 0;
          progressBar.style.width = `${percentage}%`;
          progressPercent.textContent = `${percentage}%`;

          // Ensure polling is active
          if (!pollingInterval) {
            startPolling();
          }
        } else {
          // If a broadcast just finished
          if (status.startedAt) {
            statusIdle.classList.add('hidden');
            statusActive.classList.remove('hidden');
            
            statTotal.textContent = status.totalUsers;
            statProcessed.textContent = status.processedUsers;
            statSuccess.textContent = status.successCount;
            statFailed.textContent = status.failedCount;
            statStatus.textContent = 'Completed';
            statStatus.className = 'font-bold text-emerald-400';

            statStartedAt.textContent = status.startedAt ? new Date(status.startedAt).toLocaleString() : '-';
            statFinishedAt.textContent = status.finishedAt ? new Date(status.finishedAt).toLocaleString() : '-';

            progressBar.style.width = `100%`;
            progressPercent.textContent = `100%`;
          } else {
            // No broadcast ever run in this server lifecycle
            statusIdle.classList.remove('hidden');
            statusActive.classList.add('hidden');
          }

          stopPolling();
        }
      } catch (err) {
        console.error('Error fetching broadcast status:', err);
      }
    }
  });
</script>

<%- include('partials/footer') %>
