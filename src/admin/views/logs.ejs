<%- include('partials/header') %>
<%- include('partials/sidebar') %>

<div class="flex-1 flex flex-col overflow-hidden bg-slate-950">
  <%- include('partials/navbar') %>
  
  <main class="flex-1 overflow-hidden p-6 md:p-8 flex flex-col space-y-4">
    
    <!-- Title and Action Bar -->
    <div class="flex items-center justify-between shrink-0">
      <div>
        <h2 class="text-2xl font-bold text-white tracking-tight">System Logs</h2>
        <p class="text-xs text-slate-400">View real-time application runtime alerts and debug outputs.</p>
      </div>
      <a href="/admin/logs/download" 
         class="px-4 py-2 bg-slate-900 border border-slate-800 text-xs font-semibold text-slate-300 hover:bg-slate-800 hover:text-white rounded-xl transition-all flex items-center space-x-2">
        <i class="fa-solid fa-download"></i>
        <span>Download raw log</span>
      </a>
    </div>

    <!-- Filter and Search Header -->
    <div class="bg-slate-900 border border-slate-800 p-3 rounded-xl shadow-md shrink-0">
      <form action="/admin/logs" method="GET" class="flex flex-col sm:flex-row gap-3 items-stretch sm:items-center">
        
        <!-- Search query -->
        <div class="relative flex-1">
          <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-slate-500">
            <i class="fa-solid fa-magnifying-glass text-xs"></i>
          </span>
          <input type="text" 
                 name="search" 
                 value="<%= search %>" 
                 placeholder="Search log messages, context..." 
                 class="w-full pl-9 pr-3 py-2 text-xs rounded-lg bg-slate-950 border border-slate-850 text-slate-100 placeholder-slate-600 focus:outline-none focus:border-brand-500 focus:ring-1 focus:ring-brand-500 transition-all">
        </div>

        <!-- Level Filter -->
        <div class="flex items-center space-x-2">
          <label class="text-[10px] font-bold text-slate-500 uppercase tracking-wider hidden md:block">Filter Level</label>
          <select name="level" 
                  class="bg-slate-950 border border-slate-850 text-slate-300 rounded-lg px-3 py-2 text-xs focus:outline-none focus:border-brand-500">
            <option value="all" <%= level === 'all' ? 'selected' : '' %>>ALL LEVELS</option>
            <option value="info" <%= level === 'info' ? 'selected' : '' %>>INFO</option>
            <option value="warn" <%= level === 'warn' ? 'selected' : '' %>>WARNING</option>
            <option value="error" <%= level === 'error' ? 'selected' : '' %>>ERROR</option>
            <option value="debug" <%= level === 'debug' ? 'selected' : '' %>>DEBUG</option>
          </select>
        </div>

        <button type="submit" 
                class="px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white rounded-lg text-xs font-semibold shadow transition-all">
          Query Logs
        </button>

        <% if (search || level !== 'all') { %>
          <a href="/admin/logs" class="px-4 py-2 border border-slate-800 hover:bg-slate-800 text-slate-400 hover:text-white rounded-lg text-xs font-semibold transition-all text-center">
            Reset
          </a>
        <% } %>
      </form>
    </div>

    <!-- Terminal Console Interface -->
    <div class="flex-1 bg-slate-950 border border-slate-900 rounded-xl overflow-hidden shadow-2xl flex flex-col font-mono text-xs select-text">
      <!-- Terminal Header bar -->
      <div class="h-9 bg-slate-900 border-b border-slate-950 px-4 flex items-center justify-between select-none">
        <div class="flex space-x-1.5">
          <div class="w-3 h-3 rounded-full bg-rose-500/80"></div>
          <div class="w-3 h-3 rounded-full bg-amber-500/80"></div>
          <div class="w-3 h-3 rounded-full bg-emerald-500/80"></div>
        </div>
        <span class="text-[10px] text-slate-500 font-semibold tracking-wider uppercase">nest-winston-console</span>
        <div class="w-12"></div>
      </div>

      <!-- Logs screen -->
      <div class="flex-1 overflow-y-auto p-4 space-y-1.5 scrollbar-thin scrollbar-thumb-slate-800 bg-[#060813]">
        <% if (logs.length === 0) { %>
          <div class="h-full flex flex-col items-center justify-center space-y-2 select-none text-slate-650">
            <i class="fa-solid fa-receipt text-2xl"></i>
            <p class="font-semibold text-xs">Console is quiet. No log matching criteria.</p>
          </div>
        <% } %>
        
        <% logs.forEach(log => { %>
          <div class="flex items-start space-x-2 text-slate-300 leading-relaxed hover:bg-slate-900/40 px-2 py-0.5 rounded">
            <!-- Timestamp -->
            <span class="text-slate-600 select-none shrink-0 font-medium text-[10px] pt-0.5">
              <%= new Date(log.timestamp).toLocaleString('ru-RU', { hour: '2-digit', minute: '2-digit', second: '2-digit' }) %>
            </span>

            <!-- Log Level Badge -->
            <% if (log.level === 'error') { %>
              <span class="px-1.5 py-0.2 bg-rose-500/10 border border-rose-500/20 text-rose-500 rounded text-[9px] font-bold tracking-wider shrink-0 select-none">ERR</span>
            <% } else if (log.level === 'warn') { %>
              <span class="px-1.5 py-0.2 bg-amber-500/10 border border-amber-500/20 text-amber-500 rounded text-[9px] font-bold tracking-wider shrink-0 select-none">WRN</span>
            <% } else if (log.level === 'debug') { %>
              <span class="px-1.5 py-0.2 bg-teal-500/10 border border-teal-500/20 text-teal-400 rounded text-[9px] font-bold tracking-wider shrink-0 select-none">DBG</span>
            <% } else { %>
              <span class="px-1.5 py-0.2 bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 rounded text-[9px] font-bold tracking-wider shrink-0 select-none">INF</span>
            <% } %>

            <!-- Context identifier -->
            <span class="text-slate-500 select-none shrink-0 font-bold text-[10px] pt-0.5">
              [<%= log.context || 'App' %>]:
            </span>

            <!-- Actual Message payload -->
            <span class="<%= log.level === 'error' ? 'text-rose-450 font-medium' : log.level === 'warn' ? 'text-amber-300' : 'text-slate-300' %> break-all whitespace-pre-wrap flex-1">
              <%= log.message %>
            </span>
          </div>
        <% }) %>
      </div>
    </div>

  </main>
</div>

<%- include('partials/footer') %>
